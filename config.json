{
  "podman_mode": "rootful",
  "containers": [
    {
      "name": "web",
      "image": "docker.io/library/nginx:latest",
      "env": {
        "TZ": "Europe/Copenhagen",
        "LOG_LEVEL": "info"
      },
      "ports": [
        {
          "host_ip": "0.0.0.0",
          "host_port": 8080,
          "container_port": 80,
          "protocol": "tcp"
        }
      ],
      "volumes": [
        {
          "host_path": "/data/web",
          "container_path": "/usr/share/nginx/html",
          "read_only": true
        }
      ],
      "interfaces": [
        {
          "name": "eth0",
          "network": "podman",
          "ip_address": "10.88.0.10",
          "subnet": "10.88.0.0/16",
          "gateway": "10.88.0.1",
          "dns": [
            "1.1.1.1",
            "8.8.8.8"
          ]
        }
      ],
      "restart": "always"
    }
  ]
}
