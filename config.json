{
  "podman_mode": "rootful",
  "hostname": "node1.example.com",
  "folders": [
    {
      "path": "/data/web",
      "chmod": "0755",
      "user": "0:0"
    }
  ],
  "files": [
    {
      "path": "/data/web/index.html",
      "chmod": "0644",
      "user": "0:0",
      "content": "<h1>Hello, world!</h1>\n",
      "encoding": "plain"
    }
  ],
  "interfaces": [
    {
      "name": "dummy0",
      "type": "dummy",
      "ip_address": "192.168.1.10",
      "subnet": "192.168.1.0/24"
    },
    {
      "name": "eth0",
      "ip_address": "192.168.1.20",
      "subnet": "192.168.1.0/24",
      "gateway": "192.168.1.1",
      "txqueuelen": 1000,
      "dns": [
        "1.1.1.1",
        "8.8.8.8"
      ]
    },
    {
      "name": "eth0.100",
      "type": "vlan",
      "ip_address": "192.168.100.10",
      "subnet": "192.168.100.0/24",
      "vlan": {
        "base_interface": "eth0",
        "id": 100
      }
    },
    {
      "name": "ens1f1np1",
      "ipv6_method": "link-local",
      "ipv6_addr_gen_mode": "eui64"
    },
    {
      "name": "eth1",
      "ipv4_method": "dhcp",
      "ipv6_method": "disabled"
    }
  ],
  "ostree": {
    "upload_path": "/data/ostree/update.tar",
    "apply_command": [
      "bootc",
      "switch",
      "--transport",
      "oci-archive",
      "/data/ostree/update.tar"
    ]
  },
  "firewall_ports": [
    {
      "zone": "public",
      "port": "8080",
      "protocol": "tcp"
    },
    {
      "zone": "public",
      "port": "8081",
      "protocol": "tcp"
    }
  ],
  "containers": [
    {
      "name": "web",
      "image": "docker.io/library/nginx:latest",
      "user": "0:0",
      "env": {
        "TZ": "Europe/Copenhagen",
        "LOG_LEVEL": "info"
      },
      "ports": [
        {
          "host_ip": "0.0.0.0",
          "host_port": 8081,
          "container_port": 80,
          "protocol": "tcp"
        }
      ],
      "volumes": [
        {
          "host_path": "/data/web",
          "container_path": "/usr/share/nginx/html",
          "read_only": true,
          "selinux": "Z"
        }
      ],
      "restart": "always"
    }
  ]
}
