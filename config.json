{
  "podman_mode": "rootful",
  "interfaces": [
    {
      "name": "eth0",
      "ip_address": "192.168.1.10",
      "subnet": "192.168.1.0/24",
      "gateway": "192.168.1.1",
      "dns": [
        "1.1.1.1",
        "8.8.8.8"
      ]
    }
  ],
  "containers": [
    {
      "name": "web",
      "image": "docker.io/library/nginx:latest",
      "env": {
        "TZ": "Europe/Copenhagen",
        "LOG_LEVEL": "info"
      },
      "ports": [
        {
          "host_ip": "0.0.0.0",
          "host_port": 8080,
          "container_port": 80,
          "protocol": "tcp"
        }
      ],
      "volumes": [
        {
          "host_path": "/data/web",
          "container_path": "/usr/share/nginx/html",
          "read_only": true
        }
      ],
      "restart": "always"
    }
  ]
}
